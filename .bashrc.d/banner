yadm_full_status="$(yadm -c color.status=always status -sb)"
yadm_status="$(cat - <<<$yadm_full_status | sed '1d' | cut -c1-20 | sed 's/^/|/' | sed 's/\".*//' | sed 's/ [.A-Za-z0-9/_-]*$/|/' | sed 's/^ \*//' | sort | uniq -c | sed 's/^ \+//' | paste -sd ' ' -)"
branch_lag="$(cat - <<<$yadm_full_status | head -n 1 | cut -d' ' -f3-)"

if [ "${yadm_status}${branch_lag}" != '' ]; then
  echo "🏠 $yadm_status $branch_lag"
fi

unset yadm_full_status yadm_status branch_lag
