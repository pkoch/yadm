if [ `uname -s` = 'Darwin' ]; then
  alias defbro-ff='defbro org.mozilla.firefox'
  alias defbro-c='defbro com.google.Chrome'
  alias defbro-s='defbro com.apple.Safari'
  alias defbro-ca='defbro com.openai.atlas'
else
  alias defbro-ff='xdg-settings set default-web-browser firefox.desktop'
  alias defbro-c='xdg-settings set default-web-browser chromium-browser.desktop'
fi
